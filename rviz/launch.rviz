Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Global1
        - /Global1/RobotModel1
        - /Global1/Grid1
        - /Sensors1
        - /Gmapping1/Map1
        - /Move Base1/Pose1
        - /PointCloud21
      Splitter Ratio: 0.5
    Tree Height: 553
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5844155550003052
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: LiDAR PCL2
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
