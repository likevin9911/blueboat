      <inertia ixx="0.06366" ixy="0" ixz="0" iyy="0.11553" iyz="0" izz="0.128338"/>
    </inertial>
  </link>
  <joint name="right_chasis_battery_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.8 -0.2 0.6"/>
    <parent link="base_link"/>
    <child link="right_battery_link"/>
  </joint>
  <!-- base link -->
  <link name="base_link">
  </link>
  <gazebo>
    <plugin name="p3d_plugin_wamv" filename="libgazebo_ros_p3d.so">
      <bodyName>base_link</bodyName>
      <frameName>map</frameName>
      <updateRate>15.0</updateRate>  
      <topicName>ground_truth</topicName>
      <xyzOffset>0 0 0</xyzOffset>
      <rpyOffset>0 0 0</rpyOffset>
      <gaussianNoise>0.2</gaussianNoise>
    </plugin>
  </gazebo>
  
  <link name="base_link_right">
  </link>
  <joint name="base_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_link_right"/>
  </joint>
  
  <link name="base_link_left">
  </link>
  <joint name="base_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_link_left"/>
  </joint>
  
