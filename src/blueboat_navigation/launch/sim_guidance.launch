<?xml version="1.0"?>
<launch>

  <!-- Map inflating -->
  <include file="$(find map_inflating)/launch/map_inflating.launch">
    <arg name="inflating_radius" value="3.0" />
  </include>

  <!-- Guidance node -->
  <node name="guidance_node" pkg="blueboat_navigation" type="guidance_node" output="screen">
  </node>

  <!-- Visualize in rviz -->
  <node name="rviz" pkg="rviz" type="rviz" required="true"
    args="-d $(find coverage_boustrophedon)/config/coverage.rviz" />

  <!-- Start controllers for simulated Otter USV -->
  <node name="BlueboatController" pkg="blueboat_control" type="controller" />

  

</launch>
