<?xml version="1.0" ?>

<launch>
  <!-- Arguments -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="/Odometry" />
  <!-- /blueboat/robot_localization/odometry/filtered-->
  <arg name="move_forward_only" default="false"/>

  <!-- move_base -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
    <rosparam file="$(find blueboat_navigation)/param/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find blueboat_navigation)/param/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find blueboat_navigation)/param/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find blueboat_navigation)/param/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find blueboat_navigation)/param/move_base_params.yaml" command="load" />
    <rosparam file="$(find blueboat_navigation)/param/teb_local_planner_params.yaml" command="load" />
    
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
    <!--param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" /-->

    <param name="recovery_behavior_enabled" value="false"/>
    <param name="oscillation_timeout" value="0.0"/>
    <param name="oscillation_distance" value="0.0"/>
  </node>
</launch>
