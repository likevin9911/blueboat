<?xml version="1.0" ?>

<launch>
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
        name="cloud_to_scan" output="screen">
    <remap from="cloud_in" to="/lidar_blueboat/points"/>
    <remap from="scan" to="lidar/scan"/>  

    <!-- Scan parameters -->
    <param name="min_height" value="-3.0"/>   
    <param name="max_height" value="8.0"/>
    <param name="range_min" value="0.3"/>
    <param name="range_max" value="100.0"/>   
    <param name="angle_min" value="-3.14159"/>
    <param name="angle_max" value="3.14159"/>
    <param name="angle_increment" value="0.0087266"/> <!-- ~0.5 deg -->
    <param name="scan_time" value="0.1"/>
    <param name="use_inf" value="true"/>
    <param name="target_frame" value="lidar_blueboat_link"/>
  </node>

  
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <!-- Remap scan topic to your robot's laser topic -->
    <remap from="scan" to="lidar/scan"/>
    <remap from="odom" to="odom"/>

    <!-- Coordinate frames -->
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>

    <!-- Gmapping Parameters -->
    <param name="map_update_interval" value="2.0"/>
    <param name="maxUrange" value="130.0"/>
    <param name="sigma" value="0.05"/>
    <param name="kernelSize" value="1"/>
    <param name="lstep" value="0.05"/>
    <param name="astep" value="0.05"/>
    <param name="iterations" value="5"/>
    <param name="lsigma" value="0.075"/>
    <param name="ogain" value="3.0"/>
    <param name="minimumScore" value="0.5"/>         
    <param name="linearUpdate" value="0.1"/>         
    <param name="angularUpdate" value="0.1"/>
    <param name="temporalUpdate" value="0.5"/>
    <param name="resampleThreshold" value="0.5"/>
    <param name="particles" value="30"/>
  </node>
</launch>

