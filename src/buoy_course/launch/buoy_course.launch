<?xml version="1.0"?>
<launch>

  <!-- ============================================================
       buoy_course.launch
       
       Full buoy racing circuit stack. Mirrors the structure of
       sim_guidance.launch but replaces boustrophedon/BINN with
       the three new nodes: buoy_tracker, course_planner, metrics.
       
       The guidance_node and OtterController are reused unchanged.
       ============================================================ -->

  <!-- ── Simulation arguments ── -->
  <arg name="use_sim_time"      default="true" />
  <arg name="start_x"           default="0.0" />
  <arg name="start_y"           default="0.0" />
  <arg name="log_file"          default="/tmp/buoy_course_metrics.txt" />

  <param name="/use_sim_time" value="$(arg use_sim_time)" />


  <!-- ── 3) Adaptive clustering (LiDAR perception) -->
  <node name="adaptive_clustering"
        pkg="adaptive_clustering"
        type="adaptive_clustering"
        output="screen">
    <param name="sensor_model"  value="HDL-32E" />
    <param name="z_axis_min"    value="-0.1" />   <!-- filter water surface returns -->
    <param name="z_axis_max"    value="5.0"  />   <!-- buoys typically < 2 m tall -->
    <param name="cluster_size_min" value="3"  />
    <param name="cluster_size_max" value="50" />
    <remap from="velodyne_points" to="/lidar_blueboat/points" />
  </node>


  <!-- ── 4) Buoy Tracker ── -->
  <node name="buoy_tracker_node"
        pkg="buoy_course"
        type="buoy_tracker_node"
        output="screen">
    <param name="association_radius"   value="3.5"  />
    <param name="measurement_noise"    value="0.3"  />
    <param name="confirmation_count"   value="15"    />
    <param name="max_miss_count"       value="20"   />
    <param name="buoy_count"           value="4"    />
    <param name="max_detection_range"  value="30.0" />
    <param name="min_detection_range"  value="0.1"  />
    <param name="map_frame"            value="map"  />
    <!-- Input:  /adaptive_clustering/clusters -->
    <!-- Output: /buoy_map (PoseArray), /buoy_markers (MarkerArray) -->
  </node>

  <!-- ── 5) Course Planner (A* + COLREGS waypoints) ── -->
  <node name="course_planner_node" pkg="buoy_course" type="course_planner_node" output="screen">
    <param name="buoy_count"          value="4" />
    <param name="rounding_offset"     value="5.0" />
    <param name="goal_tolerance"      value="3.0" />
    <param name="total_laps"          value="1" />
    <param name="rounding_side"       value="starboard" />
    <param name="arc_points_per_buoy" value="8" />
    <param name="start_x"             value="0.0" />
    <param name="start_y"             value="-5.0" />
  </node>


  <!-- ── 8) Metrics ── -->
  <node name="metrics_node"
        pkg="buoy_course"
        type="metrics_node"
        output="screen">
    <param name="map_frame"              value="map"  />
    <param name="rounding_radius"        value="8.0"  />
    <param name="start_x"                value="$(arg start_x)" />
    <param name="start_y"                value="$(arg start_y)" />
    <param name="start_line_half_width"  value="3.0"  />
    <param name="log_file"               value="$(arg log_file)" />
    <!-- Input:  /buoy_map, /active_buoy_id -->
    <!-- Output: /course_metrics_status (String) -->
  </node>

</launch>
