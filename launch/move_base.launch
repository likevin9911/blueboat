<?xml version="1.0" ?>

<launch>
  <!-- Arguments -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="/blueboat/robot_localization/odometry/filtered" />
  <arg name="move_forward_only" default="false"/>

 
<!-- 
  <node pkg="tf" type="static_transform_publisher"
      name="map_to_odom"
      args="0 0 0 0 0 0 map odom 100"/>
 -->

  <!-- move_base -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
    <rosparam file="$(find blueboat)/param/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find blueboat)/param/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find blueboat)/param/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find blueboat)/param/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find blueboat)/param/move_base_params.yaml" command="load" />
    <rosparam file="$(find blueboat)/param/teb_local_planner_params.yaml" command="load" />
    
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
    <!--param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" /-->
  </node>
</launch>
