<?xml version="1.0"?>
<launch>
  <arg name="namespace" default="blueboat"/>
  <arg name="model_xacro" default="$(find blueboat)/urdf/blueboat_gazebo.urdf.xacro"/>
    <!--arg name="model_xacro" default="$(find wamv_gazebo)/urdf/wamv_gazebo.urdf.xacro"/-->

  <param name="use_sim_time" value="false"/>
  <param name="robot_description" command="$(find xacro)/xacro --inorder $(arg model_xacro) namespace:=$(arg namespace)"/>


  <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher">
    <param name="use_gui" value="false"/>
  </node>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" value="50.0"/>
  </node>


  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find blueboat)/rviz/urdf.rviz" output="screen"/>
</launch>

